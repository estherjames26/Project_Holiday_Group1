# Copy this file to .env and add your keys.
# You can also place keys in ../env (project root) — they will be picked up automatically.
OPENWEATHER_API_KEY=your_openweather_api_key

# Google Cloud – enable Maps, Places, Geocoding APIs
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: OpenAI key for the summary blurb at the top of results
OPENAI_API_KEY=your_openai_api_key

# Origin airport IATA code — default shown in the sidebar (e.g. LHR, JFK, MAN)
ORIGIN_AIRPORT=LHR

# GBP → USD conversion for Cheapflights scrape (UK site lists prices in pounds)
GBP_TO_USD=1.27

# Database path (defaults to data/holiday_planner.db)
DATABASE_URL=sqlite:///data/holiday_planner.db
